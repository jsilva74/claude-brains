{
  "description": "claude-brains: capture sessions into SQLite (SessionEnd/PreCompact), recall on SessionStart + UserPromptSubmit, silent update check.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/inject.sh\"",
            "timeout": 10,
            "statusMessage": "Recalling memory..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/version-check.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/fts-recall.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/distill.sh\"",
            "timeout": 15,
            "statusMessage": "Saving memory..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/distill.sh\"",
            "timeout": 15,
            "statusMessage": "Saving memory before compaction..."
          }
        ]
      }
    ]
  }
}
